    "%@" : {
      "comment" : "A label showing the position of a team in a league standings. The argument is the position number.",
      "isCommentAutoGenerated" : true
    },
    "%@ – %@" : {
      "comment" : "A score between two teams.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ – %2$@"
          }
        }
      }
    },
    "%@ · %@" : {
      "comment" : "A match's date and kickoff time, e.g. '16 Jul · 23:30'. The arguments are the date and the time.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@ · %2$@"
          }
        }
      }
    },
    "%@ · FT" : {
