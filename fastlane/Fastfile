default_platform(:ios)

SCHEME = "BR2026"

def asc_api_key
  app_store_connect_api_key(
    key_id: ENV["ASC_KEY_ID"],
    issuer_id: ENV["ASC_ISSUER_ID"],
    key_filepath: ENV["ASC_KEY_FILEPATH"]
  )
end

platform :ios do
  desc "Run the BR2026Tests unit test suite"
  lane :test do
    scan(scheme: SCHEME, devices: ["iPhone 17"])
  end

  desc "Generate App Store screenshots for all supported locales"
  lane :screenshots do
    snapshot
  end

  desc "Push release notes (What's New) to App Store Connect"
  lane :release_notes do
    deliver(
      api_key: asc_api_key,
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      submit_for_review: false
    )
  end

  desc "Build and upload a TestFlight beta"
  lane :beta do
    api_key = asc_api_key
    build_number = (latest_testflight_build_number(api_key: api_key) + 1).to_s

    # xcodebuild's automatic signing only refreshes provisioning profiles (e.g. to
    # pick up a newly added capability like Push Notifications) when explicitly told
    # to via -allowProvisioningUpdates, and needs API key auth (with at least the
    # App Manager role — Developer-role keys can't manage certs/profiles) to do so
    # non-interactively from the command line.
    provisioning_update_args = [
      "-allowProvisioningUpdates",
      "-authenticationKeyPath \"#{ENV['ASC_KEY_FILEPATH']}\"",
      "-authenticationKeyID \"#{ENV['ASC_KEY_ID']}\"",
      "-authenticationKeyIssuerID \"#{ENV['ASC_ISSUER_ID']}\""
    ].join(" ")

    gym(
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "./build",
      clean: true,
      xcargs: "CURRENT_PROJECT_VERSION=#{build_number}",
      export_xcargs: provisioning_update_args
    )

    upload_to_testflight(api_key: api_key)
  end
end
